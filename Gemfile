source 'https://rubygems.org'

# Jekyll itself (standalone, no longer via the github-pages gem)
gem 'jekyll', '~> 4.4'

# Theme
gem 'jekyll-theme-minimal'

# Plugins (loaded automatically via this group)
group :jekyll_plugins do
  gem 'jekyll-feed'
  gem 'jekyll-sitemap'
  gem 'jekyll-paginate'
end

# Required to run `jekyll serve` on Ruby 3+
gem 'webrick'

# Default gems removed from the Ruby 3.4+ stdlib; pin them so builds stay green
gem 'csv'
gem 'base64'
gem 'logger'
